{
  "systemSetup": [
    {
      "name": "Install serve globally",
      "command": "npm install -g serve"
    }
  ],
  "templateName": "custom",
  "projectDependencies": [
    {
      "name": "Install Dependencies",
      "command": "npm install"
    }
  ],
  "codeChecks": [
    {
      "name": "Lint HTML and CSS",
      "command": "npm run lint"
    },
    {
      "name": "Validate Structure",
      "command": "npm run validate"
    }
  ],
  "buildSteps": [
    {
      "name": "Build Project",
      "command": "npm run build"
    }
  ],
  "runStep": [
    {
      "name": "Run Dev Server",
      "command": "serve public --listen 3000 --no-clipboard",
      "port": "3000"
    }
  ],
  "deploySteps": [
    {
      "name": "Deploy to Vercel",
      "command": "npx vercel --prod"
    }
  ],
  "cleanupFiles": [
    "node_modules/",
    ".vercel/",
    ".cache/",
    "*.log",
    ".stylelintcache"
  ],
  "packageManager": "npm",
  "envPaths": [
    {
      "name": "default",
      "path": ".env"
    }
  ]
}