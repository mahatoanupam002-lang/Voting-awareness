{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://voting-awareness-psi.vercel.app/schemas/pledges-file.schema.json",
  "title": "Pledges File",
  "description": "Top-level structure of public/data/pledges.json",
  "type": "object",
  "required": ["swearingIn", "deadline100", "lastUpdated", "categories", "pledges"],
  "additionalProperties": true,
  "properties": {
    "swearingIn": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date the new government was sworn in (YYYY-MM-DD)"
    },
    "deadline100": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "100-day deadline date (YYYY-MM-DD)"
    },
    "lastUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date this file was last updated (YYYY-MM-DD)"
    },
    "categories": {
      "type": "array",
      "description": "List of pledge category definitions",
      "items": {
        "type": "object",
        "required": ["id", "label", "icon", "num"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string"
          },
          "num": {
            "type": "string"
          }
        }
      }
    },
    "pledges": {
      "type": "array",
      "description": "All tracked pledges",
      "items": {
        "$ref": "pledge.schema.json"
      }
    }
  }
}
